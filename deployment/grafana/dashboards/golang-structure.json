{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 200, "title": "HTTP Metrics (Prometheus)", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }, "unit": "reqps" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 }, "id": 1,
      "title": "Request Rate", "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_requests_total{service=~\"$service\"}[$__rate_interval])) by (method, path)", "legendFormat": "{{method}} {{path}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }, "unit": "reqps" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 }, "id": 2,
      "title": "Error Rate (4xx + 5xx)", "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_requests_total{service=~\"$service\", status_code=~\"[45]..\"}[$__rate_interval])) by (status_code)", "legendFormat": "HTTP {{status_code}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }, "unit": "s" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 }, "id": 3,
      "title": "Request Duration (avg)", "type": "timeseries",
      "targets": [{ "expr": "rate(http_request_duration_seconds_sum{service=~\"$service\"}[$__rate_interval]) / rate(http_request_duration_seconds_count{service=~\"$service\"}[$__rate_interval])", "legendFormat": "{{method}} {{path}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }, "unit": "s" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 }, "id": 4,
      "title": "Request Duration (p50 / p90 / p99)", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=~\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{service=~\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=~\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 }, "id": 5,
      "title": "In-Flight", "type": "stat",
      "targets": [{ "expr": "http_requests_in_flight{service=~\"$service\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 }, "id": 6,
      "title": "Total Requests", "type": "stat",
      "targets": [{ "expr": "sum(increase(http_requests_total{service=~\"$service\"}[$__range]))", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 }, "id": 7,
      "title": "5xx Errors", "type": "stat",
      "targets": [{ "expr": "sum(increase(http_requests_total{service=~\"$service\", status_code=~\"5..\"}[$__range]))", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 }, "id": 8,
      "title": "Avg Latency", "type": "stat",
      "targets": [{ "expr": "rate(http_request_duration_seconds_sum{service=~\"$service\"}[$__rate_interval]) / rate(http_request_duration_seconds_count{service=~\"$service\"}[$__rate_interval])", "refId": "A", "instant": true }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }, "id": 201, "title": "Go Runtime (Prometheus)", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 }, "id": 9,
      "title": "Goroutines", "type": "stat",
      "targets": [{ "expr": "go_goroutines{job=\"golang-structure\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 }, "id": 10,
      "title": "Threads", "type": "stat",
      "targets": [{ "expr": "go_threads{job=\"golang-structure\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 134217728 }, { "color": "red", "value": 536870912 }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 }, "id": 11,
      "title": "Heap Alloc", "type": "stat",
      "targets": [{ "expr": "go_memstats_heap_alloc_bytes{job=\"golang-structure\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 }, "id": 12,
      "title": "Stack In Use", "type": "stat",
      "targets": [{ "expr": "go_memstats_stack_inuse_bytes{job=\"golang-structure\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 } } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 24 }, "id": 13,
      "title": "Goroutines Over Time", "type": "timeseries",
      "targets": [{ "expr": "go_goroutines{job=\"golang-structure\"}", "legendFormat": "goroutines", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }, "unit": "bytes" } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 24 }, "id": 14,
      "title": "Memory Over Time", "type": "timeseries",
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes{job=\"golang-structure\"}", "legendFormat": "heap alloc", "refId": "A" },
        { "expr": "go_memstats_heap_sys_bytes{job=\"golang-structure\"}", "legendFormat": "heap sys", "refId": "B" },
        { "expr": "go_memstats_stack_inuse_bytes{job=\"golang-structure\"}", "legendFormat": "stack in use", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "s" } },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 24 }, "id": 15,
      "title": "GC Pause Duration", "type": "timeseries",
      "targets": [{ "expr": "rate(go_gc_duration_seconds_sum{job=\"golang-structure\"}[$__rate_interval])", "legendFormat": "GC pause/sec", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }, "id": 202, "title": "Service Logs (Loki)", "type": "row" },
    {
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 32 }, "id": 16,
      "title": "All Logs", "type": "logs",
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{ "datasource": { "type": "loki", "uid": "" }, "expr": "{compose_service=\"golang-structure\"} | json", "refId": "A" }]
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 44 }, "id": 17,
      "title": "Error Logs Only", "type": "logs",
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{ "datasource": { "type": "loki", "uid": "" }, "expr": "{compose_service=\"golang-structure\", statusCode=~\"[45]..\"} | json", "refId": "A" }]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["golang-structure", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_requests_total, service)",
        "includeAll": true, "multi": true,
        "name": "service",
        "query": "label_values(http_requests_total, service)",
        "refresh": 2, "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Golang Structure - Service",
  "uid": "golang-structure-dashboard",
  "version": 1
}
